#!/usr/bin/env bash

# USAGE:
#
#  measure-network-traffic [--phase N]
#
# EXAMPLES:
#  measure-network-traffic           # Run all phases sequentially with pause points
#  measure-network-traffic --phase 1 # Run only Phase 1 (baseline)
#  measure-network-traffic --phase 3 # Re-run only Phase 3 (model pull capture)
#
# PHASES:
#  1 — Baseline:         ports and routing table before Ollama starts
#  2 — Ollama Startup:   capture outbound connections when Ollama starts
#  3 — Model Pull:       capture every connection during model download
#  4 — Inference:        capture connections during a local prompt (should be zero)
#  5 — Telemetry Audit:  examine Ollama update and phone-home behaviour
#  6 — Containment Test: apply firewall rules and verify inference still works
#
# DESCRIPTION:
#  Automates all network observation exercises from Lab 5: Assess the Lab.
#  Each phase pauses before and after so you can make configuration changes
#  (firewall rules, Ollama environment variables, etc.) and re-run any phase
#  individually to measure the effect of those changes.
#
#  Artifacts are written to ~/artifacts/lab5/ so successive runs can be
#  compared side by side.
#

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
MODEL="granite4:3b"
ARTIFACTS_DIR="${HOME}/artifacts/lab5"
TCPDUMP_PID_FILE="${ARTIFACTS_DIR}/.tcpdump.pid"
PHASE_ARG="${2:-}"      # value after --phase flag
RUN_PHASE="${PHASE_ARG}"

# ── Parse arguments ───────────────────────────────────────────────────────────
if [[ "${1:-}" == "--phase" ]]; then
    if [[ -z "${2:-}" ]]; then
        echo "Usage: measure-network-traffic [--phase N]"
        echo "  Phases: 1=baseline  2=startup  3=pull  4=inference  5=telemetry  6=containment"
        exit 1
    fi
    RUN_PHASE="${2}"
elif [[ -n "${1:-}" ]]; then
    echo "Usage: measure-network-traffic [--phase N]"
    exit 1
fi

mkdir -p "${ARTIFACTS_DIR}"

# ── Colour helpers ────────────────────────────────────────────────────────────
BOLD='\033[1m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
RESET='\033[0m'

header()  { echo -e "\n${CYAN}══════════════════════════════════════════════════════${RESET}"; \
            echo -e "${CYAN}  $*${RESET}"; \
            echo -e "${CYAN}══════════════════════════════════════════════════════${RESET}"; }
info()    { echo -e "${BOLD}▶ $*${RESET}"; }
success() { echo -e "${GREEN}✔ $*${RESET}"; }
warn()    { echo -e "${YELLOW}⚠ $*${RESET}"; }
fail()    { echo -e "${RED}✘ $*${RESET}"; exit 1; }
note()    { echo -e "  ${YELLOW}NOTE: $*${RESET}"; }

# ── Helpers ───────────────────────────────────────────────────────────────────

# Stop any running tcpdump capture started by this script
stop_capture() {
    if [[ -f "${TCPDUMP_PID_FILE}" ]]; then
        local pid
        pid=$(cat "${TCPDUMP_PID_FILE}")
        if kill -0 "${pid}" 2>/dev/null; then
            sudo kill "${pid}" 2>/dev/null || true
            sleep 1
            info "Packet capture stopped (PID ${pid})."
        fi
        rm -f "${TCPDUMP_PID_FILE}"
    fi
}

# Clean up on unexpected exit
trap 'stop_capture' EXIT

# Start a tcpdump capture in the background, save PID to file
# Usage: start_capture <output.pcap>
start_capture() {
    local outfile="$1"
    stop_capture  # ensure no leftover capture is running
    sudo tcpdump -i any -n 'not port 22' -w "${outfile}" &>/dev/null &
    echo $! > "${TCPDUMP_PID_FILE}"
    success "Packet capture started → ${outfile}"
    note "PID stored in ${TCPDUMP_PID_FILE} — capture stops when you continue."
}

# Resolve a list of IPs (one per line) to org/hostname and write a report
# Usage: resolve_ips <input-ip-list.txt> <output-report.txt>
resolve_ips() {
    local ipfile="$1"
    local outfile="$2"
    info "Resolving ${ipfile} to organisation names..."
    note "This queries whois and DNS — may take a moment per IP."
    : > "${outfile}"
    while IFS= read -r ip; do
        [[ -z "${ip}" ]] && continue
        # Skip loopback and link-local
        if echo "${ip}" | grep -qE '^(127\.|::1|169\.254\.)'; then
            continue
        fi
        {
            echo "━━━ ${ip} ━━━"
            echo "  PTR:  $(dig -x "${ip}" +short +time=3 +tries=1 2>/dev/null | head -3 || echo 'no PTR')"
            echo "  ORG:  $(whois "${ip}" 2>/dev/null | grep -E "^OrgName|^org-name|^netname|^descr" | head -2 || echo 'whois unavailable')"
            echo ""
        } | tee -a "${outfile}"
    done < "${ipfile}"
    success "Resolution report written to: ${outfile}"
}

# Pause and prompt the student before continuing
# Usage: pause_for_changes "message"
pause_for_changes() {
    local msg="${1:-Make any configuration changes now, then press ENTER to continue.}"
    echo ""
    echo -e "${YELLOW}┌──────────────────────────────────────────────────────┐${RESET}"
    echo -e "${YELLOW}│  STOP — LAB CHANGE POINT                             │${RESET}"
    echo -e "${YELLOW}└──────────────────────────────────────────────────────┘${RESET}"
    echo ""
    echo "  ${msg}"
    echo ""
    read -rp "  Press ENTER to continue to the next phase, or Ctrl-C to exit..."
    echo ""
}

# ── Phase runner ──────────────────────────────────────────────────────────────
run_phase() {
    local n="$1"
    [[ -n "${RUN_PHASE}" && "${RUN_PHASE}" != "${n}" ]] && return 0

    case "${n}" in
        1) phase_1_baseline ;;
        2) phase_2_startup ;;
        3) phase_3_pull ;;
        4) phase_4_inference ;;
        5) phase_5_telemetry ;;
        6) phase_6_containment ;;
    esac
}

# =============================================================================
# PHASE 1 — Baseline: ports and routing table before Ollama starts
# =============================================================================
phase_1_baseline() {
    header "PHASE 1 — Baseline: Network State Before Ollama"
    info "Recording the clean network state before starting Ollama."
    note "This is your reference point. Every port and connection seen in later"
    note "phases will be compared against this baseline."
    note "Ensure Ollama is NOT running before continuing. Stop it with: pkill ollama"
    echo ""

    if pgrep -x ollama >/dev/null 2>&1; then
        warn "Ollama appears to be running. Stop it first for a clean baseline:"
        echo "  pkill ollama"
        echo ""
        read -rp "  Press ENTER once Ollama is stopped..."
        echo ""
    fi

    local ports_file="${ARTIFACTS_DIR}/phase1-baseline-ports.txt"
    local routes_file="${ARTIFACTS_DIR}/phase1-baseline-routes.txt"

    info "Capturing all listening ports and established connections..."
    note "Command: ss -tulnp"
    note "  -t TCP   -u UDP   -l listening   -n numeric   -p process"
    echo ""
    ss -tulnp | tee "${ports_file}"
    success "Port baseline written to: ${ports_file}"

    echo ""
    info "Capturing routing table..."
    note "The routing table shows which network interfaces traffic exits from."
    note "The default route (0.0.0.0/0) is the gateway for all external traffic."
    echo ""
    ip route show | tee "${routes_file}"
    success "Route baseline written to: ${routes_file}"

    echo ""
    success "Phase 1 complete."
    pause_for_changes "Review the baseline output above and record it in your lab report.
  When ready, start Ollama in another terminal:  ollama serve &
  Then press ENTER to begin Phase 2 — Ollama startup capture."
}

# =============================================================================
# PHASE 2 — Ollama Startup: capture outbound connections when Ollama starts
# =============================================================================
phase_2_startup() {
    header "PHASE 2 — Ollama Startup: Capture Connections at Start"
    info "Capturing all outbound connections made when Ollama first starts."
    note "Ollama may contact its update server or registry at startup."
    note "This phase answers: does Ollama phone home before you even run a model?"
    echo ""
    note "Ensure Ollama is NOT already running. This phase will start it for you."
    echo ""

    if pgrep -x ollama >/dev/null 2>&1; then
        warn "Ollama is already running. Stop it so we can capture the startup sequence:"
        echo "  pkill ollama"
        read -rp "  Press ENTER once stopped..."
        echo ""
    fi

    local pcap_file="${ARTIFACTS_DIR}/phase2-startup.pcap"
    local ports_file="${ARTIFACTS_DIR}/phase2-ports-after-start.txt"
    local ip_file="${ARTIFACTS_DIR}/phase2-external-ips.txt"
    local resolve_file="${ARTIFACTS_DIR}/phase2-ip-resolution.txt"

    info "Starting packet capture (excluding port 22 / SSH)..."
    start_capture "${pcap_file}"

    echo ""
    info "Starting Ollama..."
    ollama serve &>/dev/null &
    OLLAMA_PID=$!
    info "Ollama started (PID ${OLLAMA_PID}). Waiting 15 seconds for startup traffic..."
    sleep 15

    stop_capture

    echo ""
    info "Checking what address Ollama is listening on..."
    note "Expected sovereign result: 127.0.0.1:11434 (loopback only)."
    note "A binding of 0.0.0.0:11434 means Ollama is reachable from the network — a"
    note "sovereignty concern on any system connected to a broader infrastructure."
    echo ""
    ss -tulnp | grep ollama | tee "${ports_file}" || echo "  (ollama not found in ss output)"

    echo ""
    info "Extracting external IP addresses from startup capture..."
    sudo tcpdump -r "${pcap_file}" -n 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | grep -vE '^(127\.|10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[01])\.)' \
        | sort -u \
        > "${ip_file}" || true

    IP_COUNT=$(wc -l < "${ip_file}" | tr -d ' ')
    if [[ "${IP_COUNT}" -eq 0 ]]; then
        success "No external IPs contacted at startup — sovereign result."
    else
        warn "${IP_COUNT} external IP(s) contacted at Ollama startup:"
        cat "${ip_file}"
        echo ""
        resolve_ips "${ip_file}" "${resolve_file}"
    fi

    echo ""
    info "Stopping Ollama (will be restarted cleanly in later phases)..."
    kill "${OLLAMA_PID}" 2>/dev/null || pkill ollama 2>/dev/null || true
    sleep 2

    echo ""
    success "Phase 2 complete. Artifacts:"
    echo "  Pcap:       ${pcap_file}"
    echo "  Ports:      ${ports_file}"
    [[ "${IP_COUNT}" -gt 0 ]] && echo "  IPs:        ${ip_file}" && echo "  Resolution: ${resolve_file}"

    pause_for_changes "Record your findings in the lab report Connection Inventory Table.
  You may change Ollama's bind address before Phase 3 by setting:
    export OLLAMA_HOST=127.0.0.1:11434
  Then press ENTER to continue to Phase 3 — model pull capture."
}

# =============================================================================
# PHASE 3 — Model Pull: capture every connection during model download
# =============================================================================
phase_3_pull() {
    header "PHASE 3 — Model Pull: Capture Connections During Download"
    info "This phase captures every outbound connection made while pulling ${MODEL}."
    note "This is where the most significant external traffic occurs."
    note "You will see: which CDN/cloud provider hosts the model weights,"
    note "which IPs are contacted, and under whose legal jurisdiction they operate."
    note "This directly tests the Guide's containment question:"
    note "  'Under whose legal jurisdiction does that infrastructure operate?'"
    echo ""
    note "Ensure Ollama is running:  ollama serve &"
    echo ""

    if ! pgrep -x ollama >/dev/null 2>&1; then
        info "Ollama is not running. Starting it now..."
        ollama serve &>/dev/null &
        sleep 5
        success "Ollama started."
    fi

    local pcap_file="${ARTIFACTS_DIR}/phase3-model-pull.pcap"
    local ip_file="${ARTIFACTS_DIR}/phase3-external-ips.txt"
    local resolve_file="${ARTIFACTS_DIR}/phase3-ip-resolution.txt"

    info "Starting packet capture..."
    start_capture "${pcap_file}"

    echo ""
    info "Pulling model: ${MODEL}"
    note "Watch the pull output — 'verifying sha256 digest' confirms layer integrity."
    echo ""
    ollama pull "${MODEL}"

    echo ""
    stop_capture

    echo ""
    info "Extracting unique external destination IPs..."
    sudo tcpdump -r "${pcap_file}" -n 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | grep -vE '^(127\.|10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[01])\.)' \
        | sort -u \
        > "${ip_file}" || true

    echo ""
    info "External IPs contacted during model pull:"
    cat "${ip_file}"

    echo ""
    resolve_ips "${ip_file}" "${resolve_file}"

    echo ""
    info "Full resolution report:"
    cat "${resolve_file}"

    echo ""
    warn "KEY QUESTIONS — answer these in your lab report:"
    echo "  1. Where are the model weights served from (CDN/cloud provider)?"
    echo "  2. What legal jurisdiction does that infrastructure operate under?"
    echo "  3. Does this match the Guide's CLOUD Act discussion?"
    echo "  4. Would this pull succeed in an air-gapped sovereign deployment?"

    echo ""
    success "Phase 3 complete. Artifacts:"
    echo "  Pcap:       ${pcap_file}"
    echo "  IPs:        ${ip_file}"
    echo "  Resolution: ${resolve_file}"

    pause_for_changes "Record the connection inventory in your lab report.
  To test a different Ollama registry or mirror, configure it before Phase 4.
  Then press ENTER to continue to Phase 4 — inference capture."
}

# =============================================================================
# PHASE 4 — Inference: capture connections during a local prompt
# =============================================================================
phase_4_inference() {
    header "PHASE 4 — Inference: Capture Connections During a Local Prompt"
    info "Capturing network activity while running a prompt against ${MODEL}."
    note "No model pull occurs — the model is already loaded from Phase 3."
    note "Expected sovereign result: ZERO external connections."
    note "If external connections appear during inference, this is a containment"
    note "failure. The Guide calls this 'quietly defeating all hardware sovereignty.'"
    echo ""

    if ! pgrep -x ollama >/dev/null 2>&1; then
        info "Ollama is not running. Starting it now..."
        ollama serve &>/dev/null &
        sleep 5
        success "Ollama started."
    fi

    local pcap_file="${ARTIFACTS_DIR}/phase4-inference.pcap"
    local ip_file="${ARTIFACTS_DIR}/phase4-external-ips.txt"

    info "Starting packet capture (excluding loopback and SSH)..."
    sudo tcpdump -i any -n 'not port 22 and not host 127.0.0.1 and not host ::1' \
        -w "${pcap_file}" &>/dev/null &
    echo $! > "${TCPDUMP_PID_FILE}"
    success "Capture started."

    echo ""
    info "Running inference query: 'What is sovereign AI?'"
    note "This query is sent to localhost:11434 — the local Ollama server."
    echo ""
    ollama run "${MODEL}" "What is sovereign AI? Answer in two sentences." || true

    echo ""
    stop_capture

    echo ""
    info "Extracting external IPs from inference capture..."
    sudo tcpdump -r "${pcap_file}" -n 2>/dev/null \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' \
        | grep -vE '^(127\.|10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[01])\.)' \
        | sort -u \
        > "${ip_file}" || true

    IP_COUNT=$(wc -l < "${ip_file}" | tr -d ' ')
    echo ""
    if [[ "${IP_COUNT}" -eq 0 ]]; then
        success "SOVEREIGN RESULT — Zero external connections during inference."
        success "The query was processed entirely on local hardware."
    else
        echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
        echo -e "${RED}  CONTAINMENT FAILURE — External connections detected  ${RESET}"
        echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
        echo ""
        warn "${IP_COUNT} external IP(s) contacted during inference:"
        cat "${ip_file}"
        warn "Record these in your lab report as a sovereignty failure."
        warn "Identify whether the source is Ollama, a system service, or another process."
    fi

    echo ""
    success "Phase 4 complete. Artifacts:"
    echo "  Pcap:  ${pcap_file}"
    echo "  IPs:   ${ip_file}"

    pause_for_changes "Record the inference connection result in your lab report.
  This is a key sovereignty data point: inference must be fully local.
  Then press ENTER to continue to Phase 5 — telemetry and update audit."
}

# =============================================================================
# PHASE 5 — Telemetry Audit: examine Ollama update and phone-home behaviour
# =============================================================================
phase_5_telemetry() {
    header "PHASE 5 — Telemetry Audit: Ollama Update and Phone-Home Behaviour"
    info "Examining how Ollama is configured to behave in terms of unsolicited"
    info "outbound connections — update checks, telemetry, and scheduled tasks."
    note "For sovereign operation every outbound connection must be explicit and"
    note "authorised. Automated update checks and telemetry are disallowed."
    echo ""

    local report_file="${ARTIFACTS_DIR}/phase5-telemetry-audit.txt"
    : > "${report_file}"

    info "Checking Ollama environment variable options (update/network behaviour)..."
    note "OLLAMA_HOST        — bind address (default 127.0.0.1:11434)"
    note "OLLAMA_ORIGINS     — allowed CORS origins"
    note "OLLAMA_NOPRUNE     — prevent automatic model pruning"
    note "OLLAMA_KEEP_ALIVE  — how long models stay loaded in VRAM"
    echo ""
    {
        echo "=== OLLAMA ENVIRONMENT VARIABLE HELP ==="
        ollama --help 2>&1 || echo "ollama --help unavailable"
    } | tee -a "${report_file}"

    echo ""
    info "Checking Ollama systemd service configuration..."
    note "The service file shows environment variables set at the system level"
    note "and whether the service is configured for automatic startup."
    echo ""
    {
        echo ""
        echo "=== OLLAMA SYSTEMD SERVICE ==="
        systemctl cat ollama 2>/dev/null || echo "Ollama not installed as a systemd service."
        echo ""
        echo "=== OLLAMA SERVICE STATUS ==="
        systemctl status ollama 2>/dev/null | head -15 || echo "Service not found."
    } | tee -a "${report_file}"

    echo ""
    info "Checking for Ollama-related scheduled tasks (cron, systemd timers)..."
    {
        echo ""
        echo "=== CRON JOBS ==="
        crontab -l 2>/dev/null | grep -i ollama || echo "No ollama cron jobs for current user."
        ls /etc/cron.d/ 2>/dev/null | grep -i ollama || echo "No ollama entries in /etc/cron.d/"
        echo ""
        echo "=== SYSTEMD TIMERS ==="
        systemctl list-timers 2>/dev/null | grep -i ollama || echo "No ollama systemd timers."
    } | tee -a "${report_file}"

    echo ""
    info "Showing current Ollama process environment variables (if running)..."
    {
        echo ""
        echo "=== RUNNING OLLAMA PROCESS ENVIRONMENT ==="
        if pgrep -x ollama >/dev/null 2>&1; then
            local pid
            pid=$(pgrep -x ollama | head -1)
            strings "/proc/${pid}/environ" 2>/dev/null | grep -i ollama || echo "No OLLAMA_ vars set in process environment."
        else
            echo "Ollama not currently running."
        fi
    } | tee -a "${report_file}"

    echo ""
    info "Sovereign Ollama service configuration reference:"
    note "For production deployment, create /etc/systemd/system/ollama.service.d/sovereign.conf"
    cat << 'EOF'
  [Service]
  Environment="OLLAMA_HOST=127.0.0.1:11434"
  Environment="OLLAMA_NOPRUNE=1"
  Environment="OLLAMA_KEEP_ALIVE=5m"
  # Pair with iptables OUTPUT rules to block all unsolicited outbound (see Phase 6)
EOF

    echo ""
    success "Phase 5 complete. Telemetry audit written to: ${report_file}"

    pause_for_changes "Review the audit output above.
  To apply sovereign environment variables before Phase 6:
    export OLLAMA_HOST=127.0.0.1:11434
    export OLLAMA_NOPRUNE=1
  Then press ENTER to continue to Phase 6 — firewall containment test."
}

# =============================================================================
# PHASE 6 — Containment Test: apply firewall rules, verify inference still works
# =============================================================================
phase_6_containment() {
    header "PHASE 6 — Containment Test: Firewall Rules and Inference Verification"
    info "Applying iptables OUTPUT rules to block all outbound HTTP/HTTPS traffic"
    info "from this user, then verifying that local inference still works correctly."
    note "This simulates the containment layer a sovereign deployment requires."
    note "A correctly configured sovereign AI system serves inference with zero"
    note "dependency on external network access after the initial model pull."
    echo ""
    warn "This phase modifies iptables rules. They will be removed automatically"
    warn "at the end of Phase 6 and on script exit."
    echo ""
    read -rp "  Press ENTER to apply firewall rules and begin the containment test..."
    echo ""

    local CURRENT_USER
    CURRENT_USER=$(whoami)
    local report_file="${ARTIFACTS_DIR}/phase6-containment-report.txt"
    local pcap_file="${ARTIFACTS_DIR}/phase6-contained-inference.pcap"
    : > "${report_file}"

    # Cleanup function — always remove rules on exit from this phase
    remove_rules() {
        info "Removing iptables containment rules..."
        sudo iptables -D OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 443 \
            -j LOG --log-prefix "SOVEREIGN-BLOCKED: " 2>/dev/null || true
        sudo iptables -D OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 443 \
            -j DROP 2>/dev/null || true
        sudo iptables -D OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 80 \
            -j LOG --log-prefix "SOVEREIGN-BLOCKED: " 2>/dev/null || true
        sudo iptables -D OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 80 \
            -j DROP 2>/dev/null || true
        success "Containment rules removed."
    }
    trap 'stop_capture; remove_rules' EXIT

    if ! pgrep -x ollama >/dev/null 2>&1; then
        info "Ollama is not running. Starting it now..."
        ollama serve &>/dev/null &
        sleep 5
        success "Ollama started."
    fi

    echo ""
    info "Applying outbound containment rules for user: ${CURRENT_USER}"
    note "Two rules per port: LOG first (writes to kernel journal), then DROP."
    note "This lets you see WHAT would have been blocked before dropping it."
    echo ""

    # Port 443 (HTTPS) — LOG then DROP
    sudo iptables -A OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 443 \
        -j LOG --log-prefix "SOVEREIGN-BLOCKED: "
    sudo iptables -A OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 443 \
        -j DROP

    # Port 80 (HTTP) — LOG then DROP
    sudo iptables -A OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 80 \
        -j LOG --log-prefix "SOVEREIGN-BLOCKED: "
    sudo iptables -A OUTPUT -m owner --uid-owner "${CURRENT_USER}" -p tcp --dport 80 \
        -j DROP

    success "Containment rules applied (ports 80 and 443 blocked outbound)."

    echo ""
    info "Current OUTPUT rules:"
    sudo iptables -L OUTPUT -n -v --line-numbers | grep -E "SOVEREIGN|Chain OUTPUT" | head -20 || true

    echo ""
    info "Running inference query under containment..."
    note "If the model is already loaded in VRAM, this should succeed with no"
    note "external connections — proving local inference is fully self-contained."
    echo ""

    start_capture "${pcap_file}"

    INFERENCE_RESULT=""
    if ollama run "${MODEL}" "Explain chain of custody in one sentence." 2>&1; then
        INFERENCE_RESULT="PASS"
        success "Inference SUCCEEDED under containment rules."
        success "Local inference does not require external network access."
    else
        INFERENCE_RESULT="FAIL"
        warn "Inference FAILED under containment rules."
        warn "The model requires external access for inference — a sovereignty failure."
    fi

    stop_capture

    echo ""
    info "Checking kernel journal for blocked connection attempts..."
    note "SOVEREIGN-BLOCKED entries show connections that Ollama or system services"
    note "attempted to make outbound — and that the firewall prevented."
    echo ""
    {
        echo "=== CONTAINMENT TEST RESULT: ${INFERENCE_RESULT} ==="
        echo "=== BLOCKED CONNECTION ATTEMPTS (from kernel journal) ==="
        sudo journalctl -k --since "5 minutes ago" 2>/dev/null | grep "SOVEREIGN-BLOCKED" \
            || echo "No blocked connection attempts logged."
    } | tee -a "${report_file}"

    echo ""
    remove_rules
    trap 'stop_capture' EXIT  # restore original trap

    echo ""
    info "Verifying inference still works after rule removal..."
    ollama run "${MODEL}" "Confirm you are working normally." 2>&1 | head -3 || true

    echo ""
    success "Phase 6 complete. Artifacts:"
    echo "  Report: ${report_file}"
    echo "  Pcap:   ${pcap_file}"

    echo ""
    warn "REQUIRED — Record in your lab report:"
    echo "  • Did inference succeed under containment? ${INFERENCE_RESULT}"
    echo "  • Were any outbound connections blocked? (see report above)"
    echo "  • What does this tell you about the sovereignty of local inference?"
}

# =============================================================================
# Banner and run
# =============================================================================
header "Lab 5: Assess the Lab — Network Traffic Measurement"
echo ""
if [[ -n "${RUN_PHASE}" ]]; then
    echo "  Running single phase: ${RUN_PHASE}"
    echo "  Artifacts directory:  ${ARTIFACTS_DIR}"
    echo ""
    note "To run all phases sequentially: measure-network-traffic (no args)"
else
    echo "  Running all phases sequentially with pause points between each."
    echo "  Artifacts directory: ${ARTIFACTS_DIR}"
    echo ""

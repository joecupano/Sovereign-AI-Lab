#!/usr/bin/env bash

# USAGE:
#
#  create-verify-os [RELEASE_VERSION]
#
# EXAMPLE:
#  create-verify-os 24.04.4
#

# Require a release version argument
if [[ -z "$1" ]]; then
  echo "Usage: create-verify-os <RELEASE_VERSION>"
  echo "Example: create-verify-os 24.04.4"
  exit 1
fi

# =============================================================================
# Lab 2: Create OS Install Media — Ubuntu 24.04 LTS Verification Script
# =============================================================================
# This script performs all verification steps from the lab exercise.
# Each step is announced clearly so you can follow the chain of custody.
# No step is silent — every action is explained before it runs.
# =============================================================================
set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
RELEASE="24.04.4"
BASE_URL="https://releases.ubuntu.com/${RELEASE}"
ISO_NAME="ubuntu-${RELEASE}-desktop-amd64.iso"
KEY_ID_1="0x46181433FBB75451"
KEY_ID_2="0xD94AA3F0EFE21092"
ARTIFACTS_DIR="${HOME}/artifacts"
RECORD_FILE="${ARTIFACTS_DIR}/ubuntu-iso-verification-record.txt"
SHA256SUMS_FILE="${ARTIFACTS_DIR}/SHA256SUMS"
SHA256SUMS_GPG="${ARTIFACTS_DIR}/SHA256SUMS.gpg"
ISO_FILE="${ARTIFACTS_DIR}/${ISO_NAME}"
WORK_DIR="${PWD}"

# ── Ensure artifacts directory exists ─────────────────────────────────────────
if [[ ! -d "${ARTIFACTS_DIR}" ]]; then
    mkdir -p "${ARTIFACTS_DIR}"
fi

# ── Colour helpers ────────────────────────────────────────────────────────────
BOLD='\033[1m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
RESET='\033[0m'

header()  { echo -e "\n${CYAN}══════════════════════════════════════════════════════${RESET}"; \
            echo -e "${CYAN}  $*${RESET}"; \
            echo -e "${CYAN}══════════════════════════════════════════════════════${RESET}"; }
info()    { echo -e "${BOLD}▶ $*${RESET}"; }
success() { echo -e "${GREEN}✔ $*${RESET}"; }
warn()    { echo -e "${YELLOW}⚠ $*${RESET}"; }
fail()    { echo -e "${RED}✘ $*${RESET}"; exit 1; }
note()    { echo -e "  ${YELLOW}NOTE: $*${RESET}"; }

# ── Prerequisite check ────────────────────────────────────────────────────────
header "PREREQUISITE CHECK"
info "Verifying required tools are available: wget, gpg, sha256sum"
for cmd in wget gpg sha256sum stat awk; do
    if ! command -v "$cmd" &>/dev/null; then
        fail "Required command '$cmd' not found. Install it and re-run."
    fi
done
success "All required tools found."

echo ""
info "Working directory: ${WORK_DIR}"
info "ISO target:        ${ISO_NAME}"
info "Verification files will be downloaded from: ${BASE_URL}"

# =============================================================================
# STEP 1: Identify the authoritative source
# =============================================================================
header "STEP 1 — Authoritative Download Source"
info "The only authoritative source for Ubuntu Desktop ISOs is:"
echo "       https://ubuntu.com/download/desktop"
echo ""
info "This lab downloads directly from releases.ubuntu.com — the origin server"
info "that ubuntu.com/download/desktop redirects to for actual file delivery."
note "Never download Ubuntu from third-party sites, sourceforge, or unverified mirrors."
note "If you use a mirror, you MUST still complete the GPG verification below."

# =============================================================================
# STEP 2: Download the ISO and verification files
# =============================================================================
header "STEP 2 — Download ISO and Verification Files"

info "Downloading SHA256SUMS checksum file..."
echo "  Source: ${BASE_URL}/SHA256SUMS"
wget --show-progress -q -N "${BASE_URL}/SHA256SUMS" -O "${SHA256SUMS_FILE}"
success "SHA256SUMS downloaded."

info "Downloading SHA256SUMS.gpg signature file..."
echo "  Source: ${BASE_URL}/SHA256SUMS.gpg"
wget --show-progress -q -N "${BASE_URL}/SHA256SUMS.gpg" -O "${SHA256SUMS_GPG}"
success "SHA256SUMS.gpg downloaded."

echo ""
if [[ -f "${ISO_FILE}" ]]; then
    info "ISO file already present — skipping download: ${ISO_FILE}"
    note "If you suspect the file is corrupted, delete it and re-run this script."
else
    info "Downloading Ubuntu ${RELEASE} Desktop ISO (~5.7 GB — this will take a while)..."
    echo "  Source: ${BASE_URL}/${ISO_NAME}"
    wget --show-progress -q "${BASE_URL}/${ISO_NAME}" -O "${ISO_FILE}"
    success "ISO downloaded: ${ISO_FILE}"
fi

echo ""
info "Confirming all three files are present:"
ls -lah "${ISO_FILE}" "${SHA256SUMS_FILE}" "${SHA256SUMS_GPG}"

echo ""
info "Contents of SHA256SUMS (Canonical's signed hash list):"
note "This file contains the SHA-256 hashes Canonical computed at build time."
note "Your job: (a) confirm Canonical signed this file, (b) confirm your ISO matches it."
cat "${SHA256SUMS_FILE}"

# =============================================================================
# STEP 3: Retrieve Canonical's signing keys
# =============================================================================
header "STEP 3 — Retrieve Canonical's GPG Signing Keys"
info "Canonical signs Ubuntu releases with two GPG keys:"
echo "  Key 1 (older DSA):  ${KEY_ID_1}  — Ubuntu CD Image Automatic Signing Key"
echo "  Key 2 (RSA-4096):   ${KEY_ID_2}  — Ubuntu CD Image Automatic Signing Key (2012)"
echo ""
info "Retrieving both keys from the Ubuntu keyserver (keyserver.ubuntu.com)..."
note "The keyserver returns any key matching the ID you request."
note "This is why we verify fingerprints in the next step against a SECOND channel."

gpg --keyid-format long \
    --keyserver hkp://keyserver.ubuntu.com \
    --recv-keys "${KEY_ID_1}" "${KEY_ID_2}"

success "Both keys retrieved from keyserver."

echo ""
info "Displaying key fingerprints (long format):"
note "These fingerprints must match Canonical's published values at:"
note "  https://ubuntu.com/tutorials/how-to-verify-ubuntu"
note "Compare character-by-character. Do NOT trust only the key ID."

gpg --keyid-format long \
    --list-keys \
    --with-fingerprint \
    "${KEY_ID_1}" "${KEY_ID_2}"

echo ""
info "Compact fingerprint output (easier to compare with Canonical's published page):"
gpg --fingerprint "${KEY_ID_1}" "${KEY_ID_2}"

echo ""
warn "REQUIRED MANUAL STEP — Do not skip:"
echo "  1. Open https://ubuntu.com/tutorials/how-to-verify-ubuntu in a browser."
echo "  2. Copy the fingerprints for both Ubuntu CD Image signing keys."
echo "  3. Compare them character-by-character against the output above."
echo "  4. Record the UTC time of your check in your lab report."
echo ""
note "This is the second-channel verification. The keyserver alone is not sufficient"
note "as a trust anchor — CDN-delivered key material can be poisoned."

read -rp "  Press ENTER once you have verified the fingerprints against the live Ubuntu page..."

# =============================================================================
# STEP 4: Verify SHA256SUMS was signed by Canonical
# =============================================================================
header "STEP 4 — Verify GPG Signature on SHA256SUMS"
info "Verifying that SHA256SUMS was signed by Canonical's known keys..."
echo ""
info "Command: gpg --keyid-format long --verify ${SHA256SUMS_GPG} ${SHA256SUMS_FILE}"
note "A GOOD signature confirms SHA256SUMS was produced by Canonical and has not"
note "been altered since signing — closing the CDN mirror and MITM attack surface."
note "A BAD signature means STOP — the SHA256SUMS file has been tampered with."
echo ""

GPG_OUTPUT=$(gpg --keyid-format long --verify "${SHA256SUMS_GPG}" "${SHA256SUMS_FILE}" 2>&1)
echo "${GPG_OUTPUT}"

echo ""
# Check for good signatures
GOOD_COUNT=$(echo "${GPG_OUTPUT}" | grep -c "Good signature" || true)
BAD_COUNT=$(echo "${GPG_OUTPUT}"  | grep -c "BAD signature"  || true)

if [[ "${BAD_COUNT}" -gt 0 ]]; then
    fail "BAD SIGNATURE DETECTED — SHA256SUMS has been tampered with. Do NOT proceed. Re-download from releases.ubuntu.com."
elif [[ "${GOOD_COUNT}" -lt 1 ]]; then
    fail "No 'Good signature' found in GPG output. Verification failed."
else
    success "GPG signature verified: ${GOOD_COUNT} Good signature(s) from Canonical keys."
fi

echo ""
note "The 'key is not certified with a trusted signature' WARNING is expected."
note "It means you have not personally web-of-trust signed Canonical's key."
note "'Good signature' + verified fingerprint (Step 3) is sufficient assurance."

# =============================================================================
# STEP 5: Verify the ISO matches the signed checksum
# =============================================================================
header "STEP 5 — Verify ISO SHA-256 Hash"
info "With SHA256SUMS confirmed authentic, verifying the ISO against it..."
echo ""
info "Computing SHA-256 of your ISO and comparing against every entry in SHA256SUMS."
note "This step confirms the ISO is byte-for-byte identical to what Canonical built."
note "A tampered ISO or a partial download will produce a different hash and FAIL."
echo ""
info "Command: sha256sum -c ${SHA256SUMS_FILE} 2>&1 | grep -E '${ISO_NAME}'"
echo ""

HASH_RESULT=$(cd "${ARTIFACTS_DIR}" && sha256sum -c SHA256SUMS 2>&1 | grep -E "${ISO_NAME}" || true)
echo "  Result: ${HASH_RESULT}"
echo ""

if echo "${HASH_RESULT}" | grep -q "OK"; then
    success "ISO hash verification PASSED — ${ISO_NAME}: OK"
    success "The supply chain from Canonical's build system to your disk is intact."
else
    fail "ISO hash verification FAILED — the ISO does not match the signed checksum. Delete it and re-download."
fi

echo ""
info "Cross-check: manual hash comparison"
echo ""
info "  Computing raw SHA-256 of your ISO:"
ISO_HASH=$(sha256sum "${ISO_FILE}")
echo "  Your ISO:  ${ISO_HASH}"
echo ""
info "  Canonical's published hash from SHA256SUMS:"
CANONICAL_HASH=$(grep "${ISO_NAME}" "${SHA256SUMS_FILE}")
echo "  Published: ${CANONICAL_HASH}"
echo ""
if [[ "$(echo "${ISO_HASH}" | awk '{print $1}')" == "$(echo "${CANONICAL_HASH}" | awk '{print $1}')" ]]; then
    success "64-character hex strings MATCH — verification complete."
else
    fail "Hash strings do NOT match — do not use this ISO."
fi

# =============================================================================
# STEP 6: Generate chain-of-custody verification record
# =============================================================================
header "STEP 6 — Generate Chain-of-Custody Verification Record"
info "Creating a signed verification record for your evidence package..."
note "In a production sovereign deployment this would be generated by an automated"
note "pipeline and stored in an immutable audit log. Here you produce it manually."
echo ""

cat > "${RECORD_FILE}" << EOF
=== UBUNTU 24.04 LTS ISO VERIFICATION RECORD ===
Date:           $(date -u +"%Y-%m-%dT%H:%M:%SZ")
Operator:       $(whoami)@$(hostname)
Lab System:     $(uname -srm)
Script:         2-create-os-install-media.sh

=== SOURCE ===
Download URL:   ${BASE_URL}/${ISO_NAME}
Checksum URL:   ${BASE_URL}/SHA256SUMS
Signature URL:  ${BASE_URL}/SHA256SUMS.gpg
Publisher:      Canonical Ltd (UK)
Signing keys:   46181433FBB75451 / D94AA3F0EFE21092

=== GPG KEY FINGERPRINTS (local output) ===
$(gpg --fingerprint "${KEY_ID_1}" "${KEY_ID_2}" 2>&1)

=== AUTHORITATIVE FINGERPRINT SOURCE (second channel) ===
Source URL:      https://ubuntu.com/tutorials/how-to-verify-ubuntu
Checked at UTC:  $(date -u +"%Y-%m-%dT%H:%M:%SZ")
Result:          MANUALLY CONFIRMED — see lab report

=== GPG SIGNATURE VERIFICATION ===
$(gpg --keyid-format long --verify "${SHA256SUMS_GPG}" "${SHA256SUMS_FILE}" 2>&1)

=== ISO SHA-256 HASH ===
$(sha256sum "${ISO_FILE}")

=== CANONICAL PUBLISHED HASH ===
$(grep "${ISO_NAME}" "${SHA256SUMS_FILE}")

=== VERIFICATION RESULT ===
$(cd "${ARTIFACTS_DIR}" && sha256sum -c SHA256SUMS 2>&1 | grep "${ISO_NAME}")

=== RECORD INTEGRITY HASH ===
EOF

# Hash the record itself and append it
sha256sum "${RECORD_FILE}" >> "${RECORD_FILE}"

success "Verification record written to: ${RECORD_FILE}"
echo ""
info "Record contents:"
cat "${RECORD_FILE}"

# =============================================================================
# STEP 7: Optional USB write
# =============================================================================
header "STEP 7 (Optional) — Write Verified Install Media to USB"
echo ""
warn "This step ERASES the target USB device. It is OPTIONAL during this lab exercise."
echo ""
read -rp "  Do you want to write the ISO to a USB drive now? [y/N] " WRITE_USB
echo ""

if [[ "${WRITE_USB,,}" == "y" ]]; then
    info "Listing block devices — identify your USB drive carefully:"
    lsblk
    echo ""
    warn "Enter the USB device path (e.g. /dev/sdb — NOT a partition like /dev/sdb1)."
    warn "Double-check the device name. THIS OPERATION IS DESTRUCTIVE AND IRREVERSIBLE."
    read -rp "  USB device path: " USB_DEVICE
    echo ""

    if [[ ! -b "${USB_DEVICE}" ]]; then
        fail "'${USB_DEVICE}' is not a valid block device. Aborting."
    fi

    info "Writing ${ISO_NAME} to ${USB_DEVICE} using dd..."
    note "bs=4M for efficiency; oflag=sync flushes each block to hardware before proceeding."
    echo ""
    sudo dd if="${ISO_FILE}" of="${USB_DEVICE}" bs=4M status=progress oflag=sync
    echo ""
    success "Write complete. Verifying USB matches ISO..."
    echo ""

    info "Computing SHA-256 of the ISO:"
    ISO_SIZE=$(stat -c%s "${ISO_FILE}")
    ISO_HASH_VAL=$(sha256sum "${ISO_FILE}" | awk '{print $1}')
    echo "  ISO hash: ${ISO_HASH_VAL}"
    echo ""

    info "Computing SHA-256 of the same byte count from the USB device..."
    note "Reading exactly ISO_SIZE bytes from the device to avoid padding differences."
    USB_HASH_VAL=$(sudo dd if="${USB_DEVICE}" bs=4M count=$(( (ISO_SIZE + 4194303) / 4194304 )) 2>/dev/null \
                  | head -c "${ISO_SIZE}" \
                  | sha256sum \
                  | awk '{print $1}')
    echo "  USB hash: ${USB_HASH_VAL}"
    echo ""

    if [[ "${ISO_HASH_VAL}" == "${USB_HASH_VAL}" ]]; then
        success "USB VERIFIED — USB device matches the ISO exactly."
    else
        fail "USB MISMATCH — the write may be corrupted. Re-write the USB device."
    fi
else
    info "USB write skipped. You can run this step manually later using:"
    echo "  sudo dd if=${ISO_FILE} of=/dev/sdX bs=4M status=progress oflag=sync"
fi

# =============================================================================
# Summary
# =============================================================================
header "LAB 2 COMPLETE — Verification Summary"
echo ""
echo -e "  ${GREEN}✔${RESET}  SHA256SUMS downloaded from ${BASE_URL}"
echo -e "  ${GREEN}✔${RESET}  SHA256SUMS.gpg downloaded from ${BASE_URL}"
echo -e "  ${GREEN}✔${RESET}  Canonical GPG keys retrieved: ${KEY_ID_1} ${KEY_ID_2}"
echo -e "  ${GREEN}✔${RESET}  Key fingerprints displayed for manual second-channel verification"
echo -e "  ${GREEN}✔${RESET}  GPG signature on SHA256SUMS: GOOD"
echo -e "  ${GREEN}✔${RESET}  ISO SHA-256 hash matches Canonical's signed checksum"
echo -e "  ${GREEN}✔${RESET}  Chain-of-custody record written to: ${RECORD_FILE}"
echo ""
info "The ISO is verified. The OS supply chain from Canonical to your disk is intact."
info "This record is the OS-layer entry in your sovereign AI chain-of-custody package."
echo ""
note "Next lab: 3-Install-Software-Stack.md"
echo ""

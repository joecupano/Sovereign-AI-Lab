#!/usr/bin/env bash

# USAGE:
#
#  tpm-attest [--compare]
#
# EXAMPLES:
#  tpm-attest              # Run full attestation baseline (Steps 1–6)
#  tpm-attest --compare    # Post-reboot PCR comparison (Step 7)
#
# DESCRIPTION:
#  Automates all steps of the Sovereign AI Lab TPM Hardware Attestation exercise.
#  Reads the TPM's hardware identity, captures a PCR baseline, verifies Secure Boot
#  state, and produces a signed chain-of-custody attestation record.
#
#  Run with --compare after rebooting to detect any PCR deviations from the
#  baseline captured during the initial run.
#

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
ARTIFACTS_DIR="${HOME}/artifacts"
BASELINE_PCR_FILE="${ARTIFACTS_DIR}/tpm-pcr-baseline.txt"
SOVEREIGN_PCR_FILE="${ARTIFACTS_DIR}/tpm-sovereign-pcrs.txt"
EK_CERT_FILE="${ARTIFACTS_DIR}/tpm-ek-cert.der"
RECORD_FILE="${ARTIFACTS_DIR}/tpm-attestation-record.txt"
POST_REBOOT_PCR_FILE="${ARTIFACTS_DIR}/tpm-pcr-post-reboot.txt"
MODE="${1:-}"

# ── Ensure artifacts directory exists ─────────────────────────────────────────
mkdir -p "${ARTIFACTS_DIR}"

# ── Colour helpers ────────────────────────────────────────────────────────────
BOLD='\033[1m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
RESET='\033[0m'

header()  { echo -e "\n${CYAN}══════════════════════════════════════════════════════${RESET}"; \
            echo -e "${CYAN}  $*${RESET}"; \
            echo -e "${CYAN}══════════════════════════════════════════════════════${RESET}"; }
info()    { echo -e "${BOLD}▶ $*${RESET}"; }
success() { echo -e "${GREEN}✔ $*${RESET}"; }
warn()    { echo -e "${YELLOW}⚠ $*${RESET}"; }
fail()    { echo -e "${RED}✘ $*${RESET}"; exit 1; }
note()    { echo -e "  ${YELLOW}NOTE: $*${RESET}"; }

# ── Usage guard ───────────────────────────────────────────────────────────────
if [[ -n "${MODE}" && "${MODE}" != "--compare" ]]; then
    echo "Usage: tpm-attest [--compare]"
    echo "  (no args)    Run full attestation baseline — Steps 1–6"
    echo "  --compare    Post-reboot PCR comparison    — Step 7"
    exit 1
fi

# =============================================================================
# POST-REBOOT COMPARISON MODE  (tpm-attest --compare)
# =============================================================================
if [[ "${MODE}" == "--compare" ]]; then
    header "STEP 7 — Post-Reboot PCR Comparison (Detection Scenario)"
    info "This step re-reads the sovereignty-critical PCRs after reboot and"
    info "compares them against the baseline captured before the reboot."
    echo ""
    note "PCRs 0, 1, and 7 measure firmware code, firmware configuration, and"
    note "Secure Boot state respectively. In a normal environment with no firmware"
    note "changes these values must be identical across reboots."
    note "An unexpected change is a sovereign AI investigation trigger — not something"
    note "to ignore or override without documented justification."
    echo ""

    if [[ ! -f "${SOVEREIGN_PCR_FILE}" ]]; then
        fail "Baseline file not found: ${SOVEREIGN_PCR_FILE}. Run tpm-attest (without --compare) first to capture a baseline."
    fi

    info "Prerequisite check: verifying tpm2-tools is available..."
    for cmd in tpm2_pcrread; do
        if ! command -v "$cmd" &>/dev/null; then
            fail "Required command '$cmd' not found. Run tpm-attest first to install TPM tools."
        fi
    done
    success "tpm2_pcrread found."

    echo ""
    info "Re-reading sovereignty-critical PCRs (sha256:0,1,7)..."
    note "PCR 0 — BIOS/UEFI firmware code"
    note "PCR 1 — BIOS/UEFI configuration and data"
    note "PCR 7 — Secure Boot state and certificates"
    echo ""
    tpm2_pcrread sha256:0,1,7 > "${POST_REBOOT_PCR_FILE}"
    success "Post-reboot PCR values written to: ${POST_REBOOT_PCR_FILE}"

    echo ""
    info "Post-reboot PCR values:"
    cat "${POST_REBOOT_PCR_FILE}"

    echo ""
    info "Comparing against baseline: ${SOVEREIGN_PCR_FILE}"
    echo ""

    if diff "${SOVEREIGN_PCR_FILE}" "${POST_REBOOT_PCR_FILE}" > /dev/null 2>&1; then
        success "PCR MATCH — Firmware integrity confirmed."
        success "PCRs 0, 1, and 7 are identical to the baseline."
        success "No unexpected firmware or Secure Boot changes detected since baseline capture."
    else
        echo ""
        warn "PCR MISMATCH DETECTED — Diff output:"
        diff "${SOVEREIGN_PCR_FILE}" "${POST_REBOOT_PCR_FILE}" || true
        echo ""
        echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
        echo -e "${RED}  SOVEREIGNTY HOLD — INVESTIGATE BEFORE PROCEEDING   ${RESET}"
        echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
        echo ""
        warn "PCR values changed since baseline. Before continuing, answer each question:"
        echo "  1. Was a BIOS/UEFI firmware update applied between baseline and this reboot?"
        echo "  2. Was a hardware component (GPU, NIC, storage) added or replaced?"
        echo "  3. Was Secure Boot configuration modified in firmware settings?"
        echo "  4. Was the baseline captured in a different Secure Boot state than now?"
        echo ""
        note "If you can explain every difference with a documented change, update the baseline:"
        note "  tpm-attest   (re-run without --compare to capture a new baseline)"
        note "If you cannot explain the difference, treat this as a tamper event."
    fi

    echo ""
    info "Post-reboot comparison files written to: ${ARTIFACTS_DIR}"
    echo ""
    exit 0
fi

# =============================================================================
# FULL BASELINE MODE  (tpm-attest, no args)
# =============================================================================
header "TPM Hardware Attestation — Sovereign AI Lab"
echo ""
echo "  This script performs all steps of the TPM Hardware Attestation lab exercise."
echo "  Each step is announced clearly so you can follow the chain of custody."
echo "  No step is silent — every action is explained before it runs."
echo ""
echo "  STEPS:"
echo "  1. Verify TPM Presence"
echo "  2. Install TPM Tools"
echo "  3. Read TPM Identity"
echo "  4. Capture PCR Baseline Measurements"
echo "  5. Verify Secure Boot State"
echo "  6. Create Signed Baseline (Chain-of-Custody Record)"
echo ""
echo "  Run tpm-attest --compare after rebooting to execute Step 7."
echo ""
note "This script requires sudo privileges."
note "Artifacts will be written to: ${ARTIFACTS_DIR}"
echo ""
info "Press any key to continue or Ctrl-C to exit..."
read -n 1 -s -r
echo ""

# =============================================================================
# STEP 1: Verify TPM Presence
# =============================================================================
header "STEP 1 — Verify TPM Presence"
info "Checking whether the kernel sees a TPM device node..."
note "A TPM 2.0 device appears as /dev/tpm0 or /dev/tpmrm0 (the resource manager interface)."
note "If neither device is present the kernel has no TPM driver or the TPM is disabled in BIOS."
echo ""

TPM_DEVICE=""
if ls /dev/tpm* >/dev/null 2>&1; then
    TPM_DEVICE=$(ls /dev/tpm* 2>/dev/null | head -1)
    success "TPM device found: ${TPM_DEVICE}"
else
    warn "No TPM device node found under /dev/tpm*."
    echo ""
    info "Checking kernel messages for TPM-related entries..."
    sudo dmesg | grep -i tpm | head -20 || echo "  (no TPM entries in dmesg)"
    echo ""
    info "Checking TPM sysfs for version information..."
    cat /sys/class/tpm/tpm0/tpm_version_major 2>/dev/null \
        && echo "" \
        || echo "  TPM sysfs not available."
    echo ""
    echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
    echo -e "${RED}  NO TPM DETECTED — LAB CANNOT PROCEED                ${RESET}"
    echo -e "${RED}══════════════════════════════════════════════════════${RESET}"
    echo ""
    warn "No TPM was detected by the OS. Before concluding there is no TPM:"
    echo ""
    echo "  1. Verify the TPM is ENABLED in your platform BIOS:"
    echo "     Dell:   F2 at boot → Security → TPM Security → Enabled"
    echo "     HP:     F10 at boot → Security → TPM Embedded Security → Available"
    echo "     Lenovo: F1 at boot → Security → Security Chip → Active"
    echo ""
    echo "  2. Save BIOS settings, reboot, and re-run this script."
    echo ""
    note "If the TPM is confirmed absent (no header on motherboard), you are done"
    note "with this lab. Proceed to: 4-Install-LLM.md"
    echo ""
    exit 0
fi

echo ""
info "Checking TPM version via sysfs..."
TPM_VERSION=$(cat /sys/class/tpm/tpm0/tpm_version_major 2>/dev/null || echo "unknown")
echo "  TPM version major: ${TPM_VERSION}"

echo ""
info "Checking kernel TPM messages (dmesg)..."
note "This shows how the kernel enumerated and initialised the TPM at boot."
sudo dmesg | grep -i tpm | head -20 || echo "  (no TPM entries in dmesg)"

echo ""
info "Checking systemd TPM access broker service (tpm2-abrmd)..."
note "tpm2-abrmd is the userspace resource manager for TPM 2.0. It may not be"
note "installed yet — that is handled in Step 2."
sudo systemctl status tpm2-abrmd 2>/dev/null | head -10 || echo "  tpm2-abrmd not yet installed."

echo ""
info "Checking platform TPM info via SMBIOS (dmidecode)..."
note "DMI type 43 is the SMBIOS TPM Device information table, provisioned at the factory."
note "Not all platforms populate this table — absence is not a failure."
sudo dmidecode -t 43 2>/dev/null || sudo dmidecode 2>/dev/null | grep -A5 "TPM" || echo "  No SMBIOS TPM table found."

echo ""
warn "REQUIRED MANUAL STEP — Platform BIOS verification:"
echo "  Confirm the TPM is enabled and note its firmware version in your BIOS."
echo ""
echo "  Dell:   F2 at boot → Security → TPM Security"
echo "          Record: TPM Status, TPM Version, TPM firmware version"
echo ""
echo "  HP:     F10 at boot → Security → TPM Embedded Security"
echo "          Record: TPM Device, TPM State, TPM specification version"
echo ""
echo "  Lenovo: F1 at boot → Security → Security Chip"
echo "          Record: Security Chip type (Discrete TPM vs fTPM), firmware version"
echo ""
note "Document whether your platform has a DISCRETE TPM (physical chip, higher"
note "assurance) or an fTPM/PTT (runs in CPU firmware, lower isolation). This"
note "distinction is material to your sovereignty posture assessment."
echo ""
read -rp "  Press ENTER once you have verified and recorded the TPM BIOS settings..."

# =============================================================================
# STEP 2: Install TPM Tools
# =============================================================================
header "STEP 2 — Install TPM Tools"
info "Installing tpm2-tools and tpm2-abrmd..."
note "tpm2-tools:  userspace utilities for TPM 2.0 commands (tpm2_getcap, tpm2_pcrread, etc.)."
note "tpm2-abrmd:  TPM 2.0 Access Broker and Resource Manager daemon."
note "             Arbitrates access to the TPM from multiple userspace processes."
note "             Required by tpm2-tools when the kernel resource manager is not in use."
echo ""
sudo apt update
sudo apt install -y tpm2-tools tpm2-abrmd

echo ""
info "Enabling and starting the tpm2-abrmd service..."
note "Enabling the service ensures it restarts automatically after reboot."
sudo systemctl enable tpm2-abrmd
sudo systemctl start tpm2-abrmd
echo ""
sudo systemctl status tpm2-abrmd | head -10
success "tpm2-abrmd is running."

echo ""
info "Verifying tpm2-tools can communicate with the TPM..."
note "tpm2_getcap -l lists all capability categories the TPM exposes."
note "A successful response confirms the full software stack is working: kernel → abrmd → tools."
echo ""
tpm2_getcap -l 2>/dev/null | head -20
success "tpm2-tools can communicate with the TPM."

# =============================================================================
# STEP 3: Read TPM Identity
# =============================================================================
header "STEP 3 — Read TPM Identity"
info "Reading the TPM's unique hardware identity..."
note "The Endorsement Key (EK) is factory-provisioned and cryptographically bound to"
note "the physical TPM chip. It cannot be forged or transferred to another device."
note "It is the hardware-layer equivalent of a serial number — and it is the anchor"
note "of the chain-of-custody attestation the Guide requires."
echo ""

info "Attempting to retrieve the EK certificate (if provisioned by manufacturer)..."
note "Enterprise-grade discrete TPMs (Infineon, Nuvoton, STMicro) are typically"
note "provisioned with a manufacturer-signed EK certificate at the factory."
note "Consumer boards and fTPMs may not have one — that is documented, not a failure."
echo ""
if tpm2_getekcertificate -o "${EK_CERT_FILE}" 2>/dev/null; then
    success "EK certificate retrieved: ${EK_CERT_FILE}"
    EK_CERT_PRESENT="Yes"
else
    warn "No EK certificate found — the manufacturer did not provision one on this TPM."
    note "Record 'EK certificate present: No' in your lab report."
    note "This is common with firmware TPMs (fTPM/Intel PTT/AMD fTPM)."
    EK_CERT_PRESENT="No"
fi

echo ""
info "Reading TPM fixed properties (manufacturer, firmware version, vendor strings)..."
note "TPM2_PT_MANUFACTURER is a 4-byte ASCII code identifying the TPM vendor."
note "TPM2_PT_FIRMWARE_VERSION_1/2 encode the major and minor firmware version."
note "TPM2_PT_VENDOR_STRING_* encode the human-readable vendor name."
echo ""
tpm2_getcap properties-fixed 2>/dev/null | grep -E "TPM2_PT_MANUFACTURER|TPM2_PT_FIRMWARE|TPM2_PT_VENDOR|TPM2_PT_SPEC"

echo ""
info "Decoding manufacturer code to human-readable name..."
note "Common manufacturer hex codes:"
note "  414D4400 = AMD            53544D20 = STMicroelectronics"
note "  49465800 = Infineon       4D534654 = Microsoft (fTPM)"
note "  4E544300 = Nuvoton (NTC)  494E5443 = Intel (PTT/fTPM)"
echo ""
TPM_MFR_HEX=$(tpm2_getcap properties-fixed 2>/dev/null \
    | grep "TPM2_PT_MANUFACTURER" \
    | awk '{print $NF}' || echo "")
if [[ -n "${TPM_MFR_HEX}" ]]; then
    TPM_MFR_NAME=$(python3 -c "
val = '${TPM_MFR_HEX}'.strip()
b = bytes.fromhex(val[2:] if val.startswith('0x') else val)
print(b.decode('ascii', errors='replace').rstrip('\x00'))
" 2>/dev/null || echo "decode failed")
    echo "  Raw manufacturer code: ${TPM_MFR_HEX}"
    echo "  Decoded manufacturer:  ${TPM_MFR_NAME}"
    success "TPM manufacturer identified: ${TPM_MFR_NAME}"
else
    warn "Could not read TPM2_PT_MANUFACTURER from tpm2_getcap output."
    TPM_MFR_NAME="unknown"
fi

echo ""
warn "REQUIRED MANUAL STEP — Record in your lab report:"
echo "  • TPM manufacturer (from decoded output above)"
echo "  • TPM firmware version (from TPM2_PT_FIRMWARE_VERSION output above)"
echo "  • EK certificate present: ${EK_CERT_PRESENT}"
echo ""
read -rp "  Press ENTER once you have recorded the TPM identity in your lab report..."

# =============================================================================
# STEP 4: Capture PCR Baseline Measurements
# =============================================================================
header "STEP 4 — Capture PCR Baseline Measurements"
info "Reading all PCR values from the SHA-256 bank..."
note "Platform Configuration Registers (PCRs) accumulate cryptographic measurements"
note "of everything loaded during the boot sequence. They cannot be reset without a"
note "full system reboot — this makes them tamper-evident."
echo ""
note "PCR layout for sovereign AI purposes:"
note "  PCR 0 — BIOS/UEFI firmware code              ← SOVEREIGNTY CRITICAL"
note "  PCR 1 — BIOS/UEFI configuration and data     ← SOVEREIGNTY CRITICAL"
note "  PCR 2 — Option ROM code"
note "  PCR 3 — Option ROM data"
note "  PCR 4 — Boot Manager code (GRUB/bootloader)"
note "  PCR 5 — Boot Manager configuration"
note "  PCR 6 — State transitions and wake events"
note "  PCR 7 — Secure Boot state and certificates   ← SOVEREIGNTY CRITICAL"
note "  PCR 8 — OS and application measurements"
echo ""
note "PCRs 0, 1, and 7 are your firmware integrity and Secure Boot indicators."
note "An unexpected change in any of these between reboots is a tamper signal."
echo ""

info "Reading all SHA-256 PCR values..."
tpm2_pcrread sha256 > "${BASELINE_PCR_FILE}"
success "Full PCR baseline written to: ${BASELINE_PCR_FILE}"
echo ""
info "Full PCR baseline:"
cat "${BASELINE_PCR_FILE}"

echo ""
info "Reading sovereignty-critical PCRs only (sha256:0,1,7)..."
echo "=== Firmware Integrity PCRs — Baseline ===" > "${SOVEREIGN_PCR_FILE}"
echo "Captured: $(date -u +"%Y-%m-%dT%H:%M:%SZ")" >> "${SOVEREIGN_PCR_FILE}"
echo "" >> "${SOVEREIGN_PCR_FILE}"
tpm2_pcrread sha256:0,1,7 >> "${SOVEREIGN_PCR_FILE}"
success "Sovereignty-critical PCR baseline written to: ${SOVEREIGN_PCR_FILE}"
echo ""
info "Sovereignty-critical PCR values (PCRs 0, 1, 7):"
cat "${SOVEREIGN_PCR_FILE}"

echo ""
warn "REQUIRED MANUAL STEP — Paste the full PCR table in your lab report."
echo "  Highlight PCRs 0, 1, and 7 as your sovereignty-critical registers."
echo ""
read -rp "  Press ENTER once you have recorded the PCR baseline in your lab report..."

# =============================================================================
# STEP 5: Verify Secure Boot State
# =============================================================================
header "STEP 5 — Verify Secure Boot State"
info "Checking whether Secure Boot is active..."
note "Secure Boot is the UEFI-layer chain of trust that TPM PCR 7 measures."
note "When Secure Boot is enabled, the bootloader and kernel are verified against"
note "trusted certificates before execution — and that verification state is"
note "recorded in PCR 7 at boot time."
note "A disabled Secure Boot produces a different PCR 7 value and means the boot"
note "chain integrity is not measured — undermining the attestation record."
echo ""

SB_STATE="unknown"

info "Checking Secure Boot state via mokutil..."
if command -v mokutil &>/dev/null; then
    SB_OUTPUT=$(mokutil --sb-state 2>/dev/null || echo "mokutil returned an error")
    echo "  ${SB_OUTPUT}"
    if echo "${SB_OUTPUT}" | grep -qi "SecureBoot enabled"; then
        SB_STATE="Enabled"
        success "Secure Boot is ENABLED."
    elif echo "${SB_OUTPUT}" | grep -qi "SecureBoot disabled"; then
        SB_STATE="Disabled"
        warn "Secure Boot is DISABLED."
        note "For sovereign deployments, Secure Boot must be enabled."
        note "PCR 7 will not reflect a trusted boot state with Secure Boot off."
        note "Re-enable Secure Boot in your platform BIOS and re-run this script."
    fi
else
    warn "mokutil not installed. Installing now..."
    sudo apt install -y mokutil
    SB_OUTPUT=$(mokutil --sb-state 2>/dev/null || echo "mokutil returned an error")
    echo "  ${SB_OUTPUT}"
fi

echo ""
info "Checking Secure Boot state via kernel firmware interface..."
note "The SecureBoot EFI variable encodes the current Secure Boot policy state."
note "The last byte of the variable value is 1 (enabled) or 0 (disabled)."
SB_EFI=$(cat /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | xxd | head -5 || echo "  EFI variable not accessible (system may not be booted in UEFI mode)")
echo "${SB_EFI}"

echo ""
info "Checking kernel boot messages for Secure Boot confirmation..."
dmesg | grep -i "secure boot" | head -5 || echo "  (no Secure Boot entries in dmesg)"

echo ""
warn "REQUIRED MANUAL STEP — Record in your lab report:"
echo "  • Secure Boot state: ${SB_STATE}"
echo "  • If Disabled: document this as a sovereignty risk finding"
echo ""
read -rp "  Press ENTER once you have recorded the Secure Boot state..."

# =============================================================================
# STEP 6: Create Signed Baseline — Chain-of-Custody Record
# =============================================================================
header "STEP 6 — Create Signed Baseline (Chain-of-Custody Record)"
info "Assembling the TPM attestation record..."
note "This record is the hardware attestation artifact required by the Guide's"
note "chain-of-custody evidence package. It captures: platform identity, TPM identity,"
note "Secure Boot state, and the full PCR baseline — all timestamped and integrity-hashed."
note "In a production sovereign deployment this record would be:"
note "  • Signed with a key held in a sovereign HSM"
note "  • Stored in an immutable audit log"
note "  • Re-verified after every planned firmware update"
note "  • Compared against at every boot as part of remote attestation"
echo ""

PLATFORM_INFO=$(sudo dmidecode -t 1 2>/dev/null | grep -E "Manufacturer|Product" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' || echo "dmidecode unavailable")
KERNEL_VER=$(uname -r)
UBUNTU_VER=$(lsb_release -d 2>/dev/null | cut -f2 || echo "unknown")
TPM_PROPERTIES=$(tpm2_getcap properties-fixed 2>/dev/null | grep -E "TPM2_PT_MANUFACTURER|TPM2_PT_FIRMWARE|TPM2_PT_VENDOR|TPM2_PT_SPEC" || echo "unavailable")
SB_STATUS=$(mokutil --sb-state 2>/dev/null || dmesg | grep -i "secure boot" | head -3 || echo "unknown")
PCR_FULL=$(tpm2_pcrread sha256 2>/dev/null || echo "unavailable")
GPG_SIGNED=""

info "Writing record to: ${RECORD_FILE}"

cat > "${RECORD_FILE}" << EOF
=== TPM ATTESTATION BASELINE RECORD ===
Date:             $(date -u +"%Y-%m-%dT%H:%M:%SZ")
Operator:         $(whoami)@$(hostname)
Platform:         ${PLATFORM_INFO}
Kernel:           ${KERNEL_VER}
Ubuntu Version:   ${UBUNTU_VER}
Script:           tpm-attest

=== TPM IDENTITY ===
EK Certificate:   ${EK_CERT_PRESENT}
Manufacturer:     ${TPM_MFR_NAME} (${TPM_MFR_HEX:-unknown})

=== TPM PROPERTIES ===
${TPM_PROPERTIES}

=== SECURE BOOT STATE ===
${SB_STATUS}

=== PCR SHA-256 BASELINE (full) ===
${PCR_FULL}

=== SOVEREIGNTY-CRITICAL PCRs (0, 1, 7) ===
$(cat "${SOVEREIGN_PCR_FILE}")

=== RECORD INTEGRITY HASH ===
EOF

# Hash the record itself and append it — tamper-evident self-seal
sha256sum "${RECORD_FILE}" >> "${RECORD_FILE}"
success "Attestation record written to: ${RECORD_FILE}"

echo ""
info "Record contents:"
cat "${RECORD_FILE}"

echo ""
info "Listing all attestation artifacts in ${ARTIFACTS_DIR}:"
ls -lah "${ARTIFACTS_DIR}"/tpm-* 2>/dev/null || true

# =============================================================================
# Summary
# =============================================================================
header "LAB COMPLETE — TPM Attestation Summary"
echo ""
echo -e "  ${GREEN}✔${RESET}  TPM device confirmed: ${TPM_DEVICE}"
echo -e "  ${GREEN}✔${RESET}  TPM tools installed: tpm2-tools tpm2-abrmd"
echo -e "  ${GREEN}✔${RESET}  TPM manufacturer identified: ${TPM_MFR_NAME}"
echo -e "  ${GREEN}✔${RESET}  EK certificate present: ${EK_CERT_PRESENT}"
echo -e "  ${GREEN}✔${RESET}  PCR baseline captured (all SHA-256 registers)"
echo -e "  ${GREEN}✔${RESET}  Sovereignty-critical PCRs (0,1,7) saved: ${SOVEREIGN_PCR_FILE}"
echo -e "  ${GREEN}✔${RESET}  Secure Boot state recorded: ${SB_STATE}"
echo -e "  ${GREEN}✔${RESET}  Chain-of-custody attestation record written: ${RECORD_FILE}"
echo ""
info "This record is the hardware attestation artifact for your sovereign AI"
info "chain-of-custody evidence package."
echo ""
warn "REQUIRED — Step 7: Post-Reboot PCR Comparison"
echo ""
echo "  Reboot the system, then run:"
echo ""
echo "      tpm-attest --compare"
echo ""
echo "  This re-reads PCRs 0, 1, and 7 and diffs them against the baseline above."
echo "  In a normal environment with no firmware changes they must be identical."
echo "  Record the comparison result (Match / Mismatch) in your lab report."
echo ""
note "Next lab: 4-Install-LLM.md"
echo ""
